local Afk_Auto_Play = function()
	character_available()
	if auto_afk then
		while task.wait() do
			if not auto_afk then break end
			-- if not plr_stats.isLoaded then continue end
			
			if current_screen == "Title" then
				aac_start()
			end
			
			if current_screen == "Rest" then
				aac_ready()
				current_screen = nil
			end
			
			if current_screen == "Encounter" then
				local child = {
					plr.PlayerGui.EncounterGUI.EncounterFrame.Background.Option1,
					plr.PlayerGui.EncounterGUI.EncounterFrame.Background.Option2,
					plr.PlayerGui.EncounterGUI.EncounterFrame.Background.Option3,
				}
				local chosen = child[math.random(1, #child)]
				aac_encounter_choice(chosen.Title.Text)
				current_screen = nil
			end
			
			if current_screen == "Choice" then
				task.wait(1)
				local child = {}
				for _,v in pairs(plr.PlayerGui.SceneGUI.Background.Options:GetChildren()) do
					if v:IsA("UIListLayout") then continue end
					table.insert(child, v)
				end
				if not child[1] then continue end
				local chosen = child[math.random(1, #child)]
				aac_choice(chosen.Name)
				task.wait(.25)
			end
			
			if current_screen == "Combat" then
				if plr:GetAttribute("Turn") then
					local enemy = workspace.Enemies:GetChildren()[1]
					local t_skill = {}
					for i,v in pairs(skills) do
						if i == "Guard" then continue end
						table.insert(t_skill, i)
					end
					local chosen = t_skill[math.random(1, #t_skill)]
					aac_combat("Ability", enemy, "Strike")
				end
			end
			
			if current_screen == "Over" then
				aac_replay()
				current_screen = nil
				break
			end
			
		end
	end
end

